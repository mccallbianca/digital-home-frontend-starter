# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Runtime duplicates for Cloudflare Workers server-side access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Site identity
NEXT_PUBLIC_SITE_URL=https://www.h3rr.com
NEXT_PUBLIC_SITE_NAME=HERR by ECQO Holdings

# API authentication (shared secret between Frontend and Backend — must match both)
API_SECRET_KEY=your-api-secret-key

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Must be LIVE-mode price IDs in production. Test-mode IDs against a
# LIVE secret key produces "No such price" at checkout. Keep all three
# tiers in the same Stripe mode as STRIPE_SECRET_KEY above.
STRIPE_PRICE_COLLECTIVE=price_REPLACE_WITH_LIVE_COLLECTIVE_ID
STRIPE_PRICE_PERSONALIZED=price_REPLACE_WITH_LIVE_PERSONALIZED_ID
STRIPE_PRICE_ELITE=price_REPLACE_WITH_LIVE_ELITE_ID

# Client-side tier resolution (Block 3 Part 2). Mirror the server values above.
NEXT_PUBLIC_STRIPE_PRICE_COLLECTIVE=price_REPLACE_WITH_LIVE_COLLECTIVE_ID
NEXT_PUBLIC_STRIPE_PRICE_PERSONALIZED=price_REPLACE_WITH_LIVE_PERSONALIZED_ID
NEXT_PUBLIC_STRIPE_PRICE_ELITE=price_REPLACE_WITH_LIVE_ELITE_ID

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_ADDRESS=HERR by ECQO Holdings <hello@h3rr.com>
RESEND_REPLY_TO=hello@h3rr.com
RESEND_WEBHOOK_SECRET=whsec_your-resend-webhook-secret

# hCaptcha
NEXT_PUBLIC_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
HCAPTCHA_SECRET=your-hcaptcha-secret

# Stream Chat (GetStream.io)
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret
NEXT_PUBLIC_STREAM_API_KEY=your-stream-public-key

# Zoom (Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Web Push (PWA notifications) — generate via: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@your-domain.com
