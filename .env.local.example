# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site identity
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Your Brand Name

# API authentication (shared secret between Frontend and Backend — must match both)
API_SECRET_KEY=your-api-secret-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_ADDRESS=Your Name <hello@yourdomain.com>
RESEND_REPLY_TO=hello@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_your-resend-webhook-secret
